_name': 'Coolant Reservoir', 'ymin': 216.0, 'xmin': 647.0, 'ymax': 353.0, 'xmax': 850.0, 'x': None, 'y': None, 'bbox_type': 'landmark', 'semantic_reason': 'The distinct blue-colored water feature with a curvilinear shape.', 'anchor_policy': 'center'}, {'number': 5, 'location_name': 'Arrivals Pavement', 'ymin': 400.0, 'xmin': 852.0, 'ymax': 800.0, 'xmax': 920.0, 'x': None, 'y': None, 'bbox_type': 'landmark', 'semantic_reason': 'The extensive, light-grey paved area facilitating pedestrian circulation and gathering around the central features, distinct from roads.', 'anchor_policy': 'center'}]}
