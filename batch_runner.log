            "semantic_reason": "The large, multi-section grey building in the upper-left corner of the map, identified as the main service hub.",
            "anchor_policy": "center"
        },
        {
            "number": 2,
            "location_name": "Main Gathering Square",
            "ymin": 345.0,
            "xmin": 400.0,
            "ymax": 445.0,
            "xmax": 650.0,
            "x": null,
            "y": null,
            "bbox_type": "plaza",
            "semantic_reason": "The wide, light-colored paved area that serves as a central promenade, connecting the main buildings to the pool complex entrance.",
            "anchor_policy": "center"
        },
        {
            "number": 3,
            "location_name": "Central Discovery Dome",
            "ymin": 39.0,
            "xmin": 501.0,
            "ymax": 450.0,
            "xmax": 990.0,
            "x": null,
            "y": null,
            "bbox_type": "building",
            "semantic_reason": "The prominent hexagonal building with a shimmering golden roof in the upper-right section of the map.",
            "anchor_policy": "center"
        },
        {
            "number": 4,
            "location_name": "Geyser Springs",
            "ymin": 350.0,
            "xmin": 147.0,
            "ymax": 990.0,
            "xmax": 981.0,
            "x": null,
            "y": null,
            "bbox_type": "water_feature",
            "semantic_reason": "The entire expansive blue water body, featuring multiple water play structures, representing the main aquatic area.",
            "anchor_policy": "center"
        },
        {
            "number": 5,
            "location_name": "Nature Walk Gardens",
