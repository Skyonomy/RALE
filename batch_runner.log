ax":844.0,"x":null,"y":null,"bbox_type":"landmark","semantic_reason":"The smaller golden hexagonal structure, visually similar to the larger core but distinct in size and position.","anchor_policy":"center"},{"number":4,"location_name":"Rainwater Harvesting Basin","ymin":612.0,"xmin":111.0,"ymax":875.0,"xmax":543.0,"x":null,"y":null,"bbox_type":"landmark","semantic_reason":"The distinctive blue, polygonal water body identified by its label text and unique color.","anchor_policy":"center"},{"number":5,"location_name":"Distribution Loading Dock","ymin":400.0,"xmin":80.0,"ymax":575.0,"xmax":490.0,"x":null,"y":null,"bbox_type":"landmark","semantic_reason":"The large, irregular grey paved area directly below the Processing and Packaging Facility, serving as a central access point.","anchor_policy":"center"}]}
