lue-colored water feature with a curvilinear shape.","anchor_policy":"center"},{"number":4,"location_name":"Aeroponic Garden Pod","ymin":288.0,"xmin":550.0,"ymax":400.0,"xmax":630.0,"x":null,"y":null,"bbox_type":"landmark","semantic_reason":"A prominent, distinct green-colored landscaped area forming a specific crescent-shaped garden pod.","anchor_policy":"center"},{"number":5,"location_name":"Arrivals Pavement","ymin":400.0,"xmin":852.0,"ymax":800.0,"xmax":950.0,"x":null,"y":null,"bbox_type":"landmark","semantic_reason":"The extensive, light-grey paved area facilitating pedestrian circulation and gathering around the central features, distinct from roads.","anchor_policy":"center"}]}
