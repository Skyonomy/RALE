eper appreciation for the thoughtful design and dedication that makes this facility truly exceptional.","labels":[{"number":1,"location_name":"Main Entrance Plaza","ymin":750.0,"xmin":120.0,"ymax":920.0,"xmax":320.0,"x":null,"y":null,"bbox_type":"landmark","semantic_reason":"The large open white area at the bottom-left of the complex, indicating a primary entry point or communal gathering space, including a circular design element.","anchor_policy":"center"},{"number":2,"location_name":"Central Surgical Block","ymin":0.0,"xmin":100.0,"ymax":749.0,"xmax":670.0,"x":null,"y":null,"bbox_type":"landmark","semantic_reason":"The dominant, large L-shaped grey building that forms the main structure of the hospital.","anchor_policy":"center"},{"number":3,"location_name":"Therapeutic Garden Courtyard","ymin":580.0,"xmin":245.0,"ymax":670.0,"xmax":335.0,"x":null,"y":null,"bbox_type":"landmark","semantic_reason":"A distinct, enclosed white rectangular space located within the main grey building, visually suitable for a courtyard or garden area.","anchor_policy":"center"},{"number":4,"location_name":"Diagnostic Imaging Wing","ymin":235.0,"xmin":505.0,"ymax":685.0,"xmax":875.0,"x":null,"y":null,"bbox_type":"landmark","semantic_reason":"The prominent, multi-faceted golden octagonal structure labeled 'Diagnostic Imaging Wing' on the map.","anchor_policy":"center"},{"number":5,"location_name":"HVAC Cooling Pond","ymin":650.0,"xmin":540.0,"ymax":980.0,"xmax":980.0,"x":null,"y":null,"bbox_type":"landmark","semantic_reason":"The large, rectangular blue body of water with three visible fountains, labeled 'HVAC Zone Cooling Pond' on the map.","anchor_policy":"center"}]}
