rk', 'semantic_reason': 'Visually identified as the extensive, central paved area connecting the main buildings and leading to other facilities, serving as a primary drop-off and gathering point.', 'anchor_policy': 'center'}, {'number': 4, 'location_name': 'Cooling Tower Reservoir', 'ymin': 600.0, 'xmin': 170.0, 'ymax': 845.0, 'xmax': 455.0, 'x': 312.5, 'y': 722.5, 'bbox_type': 'landmark', 'semantic_reason': 'Identified as the large, rectangular blue body of water, visually distinct as a reservoir.', 'anchor_policy': 'center'}, {'number': 5, 'location_name': 'Staff Wellness Garden', 'ymin': 710.0, 'xmin': 550.0, 'ymax': 880.0, 'xmax': 720.0, 'x': 635.0, 'y': 795.0, 'bbox_type': 'landmark', 'semantic_reason': 'Identified as the distinct hexagonal green space featuring a small central basin, designed as a tranquil area.', 'anchor_policy': 'center'}]}
